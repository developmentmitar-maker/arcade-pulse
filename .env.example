# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/arcade-pulse?retryWrites=true&w=majority

# JWT secret — use a long random string (min 32 chars), e.g. openssl rand -hex 32
JWT_SECRET=your_jwt_secret_at_least_32_chars_here

# Brevo (formerly Sendinblue) SMTP configuration
# 1. Sign up at https://www.brevo.com
# 2. Go to: SMTP & API → Generate a new SMTP key
# 3. Use your Brevo account email as SMTP_USER and the generated key as SMTP_PASS
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login_email@example.com
SMTP_PASS=your_brevo_smtp_key_here

# Email sender (must be a verified sender domain/address in Brevo)
EMAIL_FROM=Arcade Pulse <noreply@yourdomain.com>

# Secret to secure cron and trigger endpoints
CRON_SECRET=your_random_secret_at_least_16_chars

# Public URL of the deployed app
NEXT_PUBLIC_APP_URL=http://localhost:3000
