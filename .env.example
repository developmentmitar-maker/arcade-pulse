# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/arcade-pulse?retryWrites=true&w=majority

# JWT secret — use a long random string (min 32 chars), e.g. openssl rand -hex 32
JWT_SECRET=your_jwt_secret_at_least_32_chars_here

# Resend Email Service Configuration
# 1. Sign up at https://resend.com
# 2. Go to API Keys → Create API Key
# 3. Use the generated key (starts with re_)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Email sender (use onboarding@resend.dev for testing or your verified domain)
EMAIL_FROM=Arcade Pulse <onboarding@resend.dev>

# Secret to secure cron and trigger endpoints
CRON_SECRET=your_random_secret_at_least_16_chars

# Public URL of the deployed app
NEXT_PUBLIC_APP_URL=http://localhost:3000
