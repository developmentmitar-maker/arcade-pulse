# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/arcade-pulse?retryWrites=true&w=majority

# JWT secret — use a long random string (min 32 chars), e.g. openssl rand -hex 32
JWT_SECRET=your_jwt_secret_at_least_32_chars_here

# Gmail SMTP configuration (use a Google App Password — NOT your real Gmail password)
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Create an App Password: Google Account → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Email sender address (must match SMTP_USER for Gmail)
EMAIL_FROM=Arcade Pulse <your@gmail.com>

# Secret to secure cron and trigger endpoints
CRON_SECRET=your_random_secret_at_least_16_chars

# Public URL of the deployed app
NEXT_PUBLIC_APP_URL=http://localhost:3000
